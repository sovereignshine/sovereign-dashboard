META_ACCESS_TOKEN=your_system_user_token_here
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Organic — Instagram
# Run GET /api/organic/instagram/discover to find your ig_user_id, then put it in organic_config.json

# Organic — TikTok
# 1. Create a TikTok Developer app at https://developers.tiktok.com/
# 2. Add "Login Kit" + "Video Kit" products, set redirect URI below
# 3. Paste Client Key + Secret here
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_REDIRECT_URI=http://localhost:5001/api/organic/tiktok/callback

# URL of your frontend (used for post-OAuth redirect)
DASHBOARD_URL=http://localhost:3000
